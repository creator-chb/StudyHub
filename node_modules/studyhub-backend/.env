# StudyHub 后端环境变量配置模板
# 复制此文件为 .env 并填写实际值

# =============================================
# 基础配置
# =============================================

# 服务端口
PORT=3000

# 运行环境（development / production）
NODE_ENV=development

# 前端访问地址（CORS 白名单）
FRONTEND_URL=http://localhost:8080

# =============================================
# PostgreSQL 数据库配置
# =============================================

DB_USER=postgres
DB_PASSWORD=studyhub_dev_2024
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studyhub

# 或者使用完整连接字符串（二选一）
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studyhub

# =============================================
# JWT 认证配置
# =============================================

# JWT 密钥（生产环境请使用复杂的随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT 过期时间
JWT_EXPIRES_IN=7d

# Token 刷新过期时间
JWT_REFRESH_EXPIRES_IN=30d

# =============================================
# 可选配置
# =============================================

# Redis 缓存（当前未使用，预留）
# REDIS_URL=redis://localhost:6379
